# SkcKMS Production Environment Variables
# Copy to .env and fill in real values — NEVER commit .env to git

# Database
DB_CONNECTION_STRING=Host=<db-host>;Database=SkcKMS;Username=<db-user>;Password=<db-password>

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET_KEY=<generate-a-random-64-char-secret>

# AI API Keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
XIAOMI_MIMO_API_KEY=sk-mimo-xxxxxxxxxxxxxxxx

# LINE OA (fill only if LINE integration is enabled)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Production URL
WEB_BASE_URL=https://your-domain.ac.th
ALLOWED_HOSTS=your-domain.ac.th

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
