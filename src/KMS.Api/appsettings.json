{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/kms-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=KMS;Username=postgres;Password=123456",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyHere-MustBeAtLeast32CharactersLong!",
    "Issuer": "KMS-API",
    "Audience": "KMS-Client",
    "ExpiryInMinutes": 60
  },
  "AI": {
    "Chat": {
      "Providers": [
        {
          "Name": "OpenRouter",
          "Endpoint": "https://openrouter.ai/api/v1",
          "Model": "qwen/qwen3.6-plus:free",
          "Priority": 1,
          "Enabled": true,
          "ApiKey": "sk-or-v1-xxxxxxxxxxxxxxxxxxxx"
        },
        {
          "Name": "XiaomiMiMo",
          "Endpoint": "https://api.xiaomimimo.com/v1",
          "Model": "mimo-v2-flash",
          "Priority": 2,
          "Enabled": true,
          "ApiKey": "sk-mimo-xxxxxxxxxxxxxxxxxxxx"
        }
      ],
      "DefaultMaxTokens": 1000,
      "DefaultTemperature": 0.7
    },
    "Embedding": {
      "Dimensions": 1024,
      "QueueOnAllFailed": true,
      "Providers": [
        {
          "Name": "OpenRouter",
          "Endpoint": "https://openrouter.ai/api/v1/embeddings",
          "Model": "qwen/qwen3-embedding",
          "Priority": 1,
          "Enabled": true,
          "ApiKey": "sk-or-v1-xxxxxxxxxxxxxxxxxxxx"
        }
      ]
    }
  },
  "Storage": {
    "Provider": "Local",
    "BasePath": "uploads",
    "MaxFileSizeMB": 100
  },
  "LineOA": {
    "Enabled": false,
    "ChannelSecret": "",
    "ChannelAccessToken": "",
    "ApiBaseUrl": "https://api.line.me/v2/bot",
    "MaxReplyLength": 1200,
    "WebBaseUrl": "http://localhost:5173",
    "EnableCommandRouting": true,
    "MaxSearchResults": 3,
    "EventDedupWindowMinutes": 10,
    "ReplyMaxRetries": 3,
    "ReplyRetryBaseDelayMs": 250,
    "InboundRateLimitWindowSeconds": 60,
    "InboundRateLimitMaxMessages": 20,
    "TelemetryWindowSeconds": 60,
    "AlertDuplicateEventsPerWindow": 50,
    "AlertRateLimitedEventsPerWindow": 30,
    "AlertReplyFailuresPerWindow": 10,
    "AlertProcessingErrorsPerWindow": 10,
    "EnableExternalAlerts": false,
    "ExternalAlertWebhookUrl": "",
    "ExternalAlertCooldownSeconds": 300
  },
  "FileStorage": {
    "Provider": "local"
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin123",
    "Secure": false,
    "Bucket": "kms",
    "PublicUrl": "http://localhost:9000/kms"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "UseSsl": false,
    "Username": "",
    "Password": "",
    "SenderEmail": "noreply@kms.rmuti.ac.th",
    "SenderName": "KMS - ระบบจัดการองค์ความรู้",
    "Enabled": false,
    "WebBaseUrl": "http://localhost:5173"
  },
  "AllowedHosts": "*"
}
